# LƯU Ý: KHÔNG viết comment (#) ở CÙNG DÒNG với giá trị.
# Trình đọc .env sẽ lấy luôn cả comment làm giá trị. Comment để ở dòng riêng.

# ===== Supabase =====
SUPABASE_URL=https://xxxx.supabase.co
# service_role key: Settings > API > service_role (KHÔNG để lộ, chỉ dùng ở worker)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ===== LLM =====
# Thứ tự ưu tiên (phân cách dấu phẩy), provider lỗi/rate-limit thì tự chuyển sang cái kế
# nvidia (free, chính) → openrouter (free, hay rate-limit 429) → fireworks (trả phí, tấm chắn cuối)
LLM_PROVIDER=nvidia,openrouter,fireworks
OPENROUTER_API_KEY=sk-or-...
# benchmark 2026-07: gemma-4-31b dịch zh→vi tốt nhất trong nhóm :free còn sống
OPENROUTER_MODEL=google/gemma-4-31b-it:free
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/deepseek-v4-flash
NVIDIA_API_KEY=nvapi-...
# NVIDIA_API_KEYS: khai NHIỀU key (phân cách phẩy) để chạy SONG SONG — mỗi key 1 lane
# 40 RPM. Đặt TRANSLATOR_CONCURRENCY = số key. Để trống thì dùng NVIDIA_API_KEY ở trên.
NVIDIA_API_KEYS=nvapi-key1,nvapi-key2
# diffusion-gemma: sinh token nhanh + độ trễ thấp hơn hẳn qwen (đổi 2026-07)
NVIDIA_MODEL=google/diffusiongemma-26b-a4b-it

# ===== Crawler =====
CRAWL_INTERVAL_MIN=45
# HTTP_PROXY_URL: ví dụ http://user:pass@host:port — để TRỐNG nếu chưa cần
HTTP_PROXY_URL=

# ===== Worker =====
# WORKER_ID: mỗi máy chạy worker đặt tên khác nhau (worker-pc, worker-laptop...)
WORKER_ID=worker-1
TRANSLATOR_CONCURRENCY=2
# MAX_CHAPTERS_PER_DAY: cầu chì chi phí — trần tổng chương dịch/ngày
MAX_CHAPTERS_PER_DAY=1000
# STALE_JOB_MINUTES: job kẹt quá X phút thì trả về hàng đợi
STALE_JOB_MINUTES=10
